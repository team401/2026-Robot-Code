digraph {

  // Graphviz Format settings

  node [
    shape=box,
    style=rounded
  ];

  edge [
    fontsize=10
  ];


  // States

  HomingWaitForMovementState ;
  HomingWaitForStoppingState ;
  IdleState ;
  TrackHeadingState ;
  TestModeState ;
  HomingWaitForButtonState ;

  // Transitions

  HomingWaitForMovementState -> HomingWaitForStoppingState [label="When HomingWaitForMovementState finished"];
  HomingWaitForMovementState -> HomingWaitForStoppingState [label="timeout"];

  HomingWaitForStoppingState -> IdleState [label="When HomingWaitForStoppingState finished"];

  IdleState -> TrackHeadingState [label="Action == TrackHeading"];
  IdleState -> TestModeState [label="In turret test mode"];

  TrackHeadingState -> IdleState [label="Action != TrackHeading"];

  TestModeState -> IdleState [label="Not in turret test mode"];

  HomingWaitForButtonState -> IdleState [label="When HomingWaitForButtonState finished"];
  HomingWaitForButtonState -> HomingWaitForMovementState [label="Robot is enabled"];

}
